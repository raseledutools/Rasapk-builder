<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:background="#0DA4A6"
        android:orientation="vertical"
        android:paddingTop="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RasFocus"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingStart="15dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adult &amp; apps blocker"
            android:textColor="#E0F2F1"
            android:textSize="10sp"
            android:paddingStart="15dp"
            android:layout_marginBottom="30dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:id="@+id/menuBlocks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blocks"
            android:textColor="#0DA4A6"
            android:background="#FFFFFF"
            android:textStyle="bold"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:id="@+id/menuAdultBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adult Block"
            android:textColor="#FFFFFF"
            android:background="#0DA4A6"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deep Study"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Special Feature"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Statistics"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingStart="15dp" />

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upgrade to Pro"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F59E0B"
            android:layout_margin="10dp"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#0DA4A6"
            android:gravity="end|center_vertical"
            android:paddingEnd="10dp">
            <Button
                android:id="@+id/btnClose"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:backgroundTint="#0DA4A6"
                android:text="X"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/viewBlocks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="15dp" android:paddingBottom="15dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Simple Blocks" android:textColor="#FFFFFF" android:background="#0DA4A6" android:textStyle="bold" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="20dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Schedule Blocks" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Device Block" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                            <TextView android:layout_width="140dp" android:layout_height="40dp" android:text="Self Control  ▼" android:textColor="#333333" android:textStyle="bold" android:gravity="center" android:background="#F9FAFB" android:layout_marginEnd="15dp" android:elevation="1dp" />
                            <EditText android:id="@+id/breakTimeInputBlocks" android:layout_width="80dp" android:layout_height="40dp" android:hint="Min" android:inputType="number" android:background="#F9FAFB" android:gravity="center" android:layout_marginEnd="10dp"/>
                            <Button android:id="@+id/btnStartFocusBlocks" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Start Focus" android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textStyle="bold" android:insetTop="0dp" android:insetBottom="0dp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="15dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Mode:" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp" android:layout_marginEnd="15dp" />
                            <TextView android:layout_width="180dp" android:layout_height="40dp" android:text="Block Apps &amp; Web  ▼" android:textColor="#0DA4A6" android:gravity="center" android:background="#FFFFFF" android:elevation="1dp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="20dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Websites" android:textColor="#333333" android:textStyle="bold" android:textSize="20sp" android:layout_marginBottom="10dp"/>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="5dp">
                                        <EditText android:id="@+id/websiteInput" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. facebook.com" android:textSize="14sp" android:paddingStart="10dp"/>
                                    </LinearLayout>
                                    <Button android:id="@+id/btnAddWebsite" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="140dp" android:background="#E0E0E0" android:padding="1dp">
                                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                        <LinearLayout android:id="@+id/websiteListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                    </ScrollView>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                                    <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motivational Quotes" android:checked="true" android:buttonTint="#0DA4A6" android:layout_marginEnd="10dp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="30dp" android:text="Bangla  ▼" android:gravity="center" android:background="#FFFFFF" android:elevation="1dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
                                </LinearLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Applications" android:textColor="#333333" android:textStyle="bold" android:textSize="20sp" android:layout_marginBottom="10dp"/>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="5dp">
                                        <EditText android:id="@+id/appInput" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. telegram.exe" android:textSize="14sp" android:paddingStart="10dp"/>
                                    </LinearLayout>
                                    <Button android:id="@+id/btnAddApp" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginBottom="10dp">
                                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                        <LinearLayout android:id="@+id/appListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                    </ScrollView>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                    <Button android:layout_width="0dp" android:layout_weight="1" android:layout_height="35dp" android:text="Add exe..." android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textSize="10sp" android:insetTop="0dp" android:insetBottom="0dp" android:layout_marginEnd="5dp"/>
                                    <Button android:layout_width="0dp" android:layout_weight="1" android:layout_height="35dp" android:text="Add Store..." android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textSize="10sp" android:insetTop="0dp" android:insetBottom="0dp" android:layout_marginEnd="5dp"/>
                                    <Button android:layout_width="0dp" android:layout_weight="1" android:layout_height="35dp" android:text="Add title..." android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textSize="10sp" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/viewAdultBlock"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="15dp" android:paddingBottom="15dp">
                        <TextView android:id="@+id/tabSafeBrowsing1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safe Browsing" android:textColor="#FFFFFF" android:background="#0DA4A6" android:textStyle="bold" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="20dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Filter" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                        <TextView android:id="@+id/tabStrictProtocols1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Strict Protocols" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="25dp">
                            <Button android:id="@+id/btnStartFocusAdult" android:layout_width="140dp" android:layout_height="40dp" android:text="Start Focus" android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textStyle="bold" android:textSize="16sp" android:insetTop="0dp" android:insetBottom="0dp" android:layout_marginEnd="20dp"/>
                            
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mode:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
                            <TextView android:layout_width="120dp" android:layout_height="35dp" android:text="Self Control  ▼" android:textColor="#666666" android:gravity="center_vertical" android:background="#FFFFFF" android:paddingStart="10dp" android:layout_marginEnd="20dp" android:elevation="1dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Religion:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
                            <TextView android:layout_width="100dp" android:layout_height="35dp" android:text="Muslim  ▼" android:textColor="#666666" android:gravity="center_vertical" android:background="#FFFFFF" android:paddingStart="10dp" android:layout_marginEnd="20dp" android:elevation="1dp"/>
                                
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lang:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
                            <TextView android:layout_width="90dp" android:layout_height="35dp" android:text="Bangla  ▼" android:textColor="#666666" android:gravity="center_vertical" android:background="#FFFFFF" android:paddingStart="10dp" android:elevation="1dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false" android:layout_marginBottom="25dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="20dp">
                                <CheckBox android:id="@+id/chkAdult" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block Adult Websites" android:checked="true" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                                <CheckBox android:id="@+id/chkHardcore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block Hardcore Keywords" android:checked="true" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                                <CheckBox android:id="@+id/chkRomantic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block Romantic/Softcore" android:checked="true" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                                <CheckBox android:id="@+id/chkReels" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block Facebook Reels" android:checked="true" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                                <CheckBox android:id="@+id/chkShorts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block YouTube Shorts" android:checked="true" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="14sp"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Custom Keywords:" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="10dp"/>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="10dp">
                                        <EditText android:id="@+id/keywordInputAdult" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. badword" android:textSize="14sp" android:paddingStart="10dp"/>
                                    </LinearLayout>
                                    <Button android:id="@+id/btnAddKeywordAdult" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="140dp" android:background="#E0E0E0" android:padding="1dp">
                                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                        <LinearLayout android:id="@+id/keywordListContainerAdult" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                    </ScrollView>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="20dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E0E0E0" android:padding="1dp">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FAFAFA" android:orientation="horizontal" android:padding="15dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textColor="#0DA4A6" android:textSize="50sp" android:layout_marginEnd="15dp"/>
                                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clean Streak" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="April 25, 2026" android:textColor="#888888" android:textSize="12sp"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Days" android:textColor="#0DA4A6" android:textStyle="bold" android:textSize="35sp" android:layout_marginTop="-5dp"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stay focused to build your streak!" android:textColor="#E53935" android:textSize="12sp"/>
                                        </LinearLayout>
                                    </LinearLayout>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="15dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Go to AI Filter Settings >" android:textColor="#0277BD" android:textStyle="bold" android:textSize="14sp" android:layout_marginEnd="20dp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Go to Strict Protocols >" android:textColor="#0277BD" android:textStyle="bold" android:textSize="14sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_vertical" android:paddingTop="15dp">
                                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24-Hour Lockdown Mode" android:textColor="#333333" android:textStyle="bold" android:textSize="14sp" android:layout_marginBottom="15dp"/>
                                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Periodic Religious Popups" android:textColor="#333333" android:textStyle="bold" android:textSize="14sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/viewStrictProtocols"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="15dp" android:paddingBottom="15dp">
                        <TextView android:id="@+id/tabSafeBrowsing2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safe Browsing" android:textColor="#666666" android:background="#F0F2F5" android:textStyle="bold" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="20dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Filter" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                        <TextView android:id="@+id/tabStrictProtocols2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Strict Protocols" android:textColor="#FFFFFF" android:textStyle="bold" android:background="#0DA4A6" android:paddingTop="12dp" android:paddingBottom="12dp" android:paddingStart="40dp" android:paddingEnd="40dp" android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="25dp">
                            <Button android:id="@+id/btnStartFocusStrict" android:layout_width="140dp" android:layout_height="40dp" android:text="Start Focus" android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textStyle="bold" android:textSize="16sp" android:insetTop="0dp" android:insetBottom="0dp" android:layout_marginEnd="20dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mode:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
                            <TextView android:layout_width="120dp" android:layout_height="35dp" android:text="Self Control  ▼" android:textColor="#666666" android:gravity="center_vertical" android:background="#FFFFFF" android:paddingStart="10dp" android:layout_marginEnd="20dp" android:elevation="1dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Religion:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
                            <TextView android:layout_width="100dp" android:layout_height="35dp" android:text="Muslim  ▼" android:textColor="#666666" android:gravity="center_vertical" android:background="#FFFFFF" android:paddingStart="10dp" android:layout_marginEnd="20dp" android:elevation="1dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lang:" android:textColor="#333333" android:textStyle="bold" android:layout_marginEnd="5dp" />
