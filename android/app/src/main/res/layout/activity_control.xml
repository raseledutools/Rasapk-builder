<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0DA4A6"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:elevation="4dp">

            <Button
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:text="☰"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:layout_marginStart="5dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RasFocus Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp"/>

            <Button
                android:id="@+id/btnClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:layout_marginEnd="5dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/viewBlocks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="10dp" android:paddingBottom="10dp" android:gravity="center">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Simple Blocks" android:textColor="#FFFFFF" android:background="#0DA4A6" android:textStyle="bold" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Schedule" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="15dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="15dp">
                            <TextView android:layout_width="100dp" android:layout_height="40dp" android:text="Self Control ▼" android:textColor="#333333" android:textStyle="bold" android:gravity="center" android:background="#F9FAFB" android:layout_marginEnd="10dp" android:elevation="1dp" />
                            <EditText android:id="@+id/breakTimeInputBlocks" android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:hint="Min" android:inputType="number" android:background="#F9FAFB" android:gravity="center" android:layout_marginEnd="10dp"/>
                            <Button android:id="@+id/btnStartFocusBlocks" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Focus" android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textStyle="bold" android:insetTop="0dp" android:insetBottom="0dp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="15dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Websites" android:textColor="#333333" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="10dp"/>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="5dp">
                                        <EditText android:id="@+id/websiteInput" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. facebook.com" android:textSize="14sp" android:paddingStart="10dp"/>
                                    </LinearLayout>
                                    <Button android:id="@+id/btnAddWebsite" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="120dp" android:background="#E0E0E0" android:padding="1dp">
                                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                        <LinearLayout android:id="@+id/websiteListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                    </ScrollView>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Applications" android:textColor="#333333" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="10dp"/>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="5dp">
                                        <EditText android:id="@+id/appInput" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. tiktok" android:textSize="14sp" android:paddingStart="10dp"/>
                                    </LinearLayout>
                                    <Button android:id="@+id/btnAddApp" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="match_parent" android:layout_height="120dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginBottom="10dp">
                                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                        <LinearLayout android:id="@+id/appListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                    </ScrollView>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/viewAdultBlock"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="10dp" android:paddingBottom="10dp" android:gravity="center">
                        <TextView android:id="@+id/tabSafeBrowsing1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Safe Browse" android:textColor="#FFFFFF" android:background="#0DA4A6" android:textStyle="bold" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                        <TextView android:id="@+id/tabStrictProtocols1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Strict Mode" android:textColor="#666666" android:textStyle="bold" android:background="#F0F2F5" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="15dp">
                        
                        <Button android:id="@+id/btnStartFocusAdult" android:layout_width="match_parent" android:layout_height="45dp" android:text="Start Focus" android:textColor="#FFFFFF" android:backgroundTint="#62AC1E" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="20dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                            <CheckBox android:id="@+id/chkAdult" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block Adult Websites" android:textColor="#333333" android:textSize="15sp" android:buttonTint="#0DA4A6" android:layout_marginBottom="5dp"/>
                            <CheckBox android:id="@+id/chkHardcore" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block Hardcore Keywords" android:textColor="#333333" android:textSize="15sp" android:buttonTint="#0DA4A6" android:layout_marginBottom="5dp"/>
                            <CheckBox android:id="@+id/chkRomantic" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block Romantic/Softcore" android:textColor="#333333" android:textSize="15sp" android:buttonTint="#0DA4A6" android:layout_marginBottom="5dp"/>
                            <CheckBox android:id="@+id/chkReels" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block Facebook Reels" android:textColor="#333333" android:textSize="15sp" android:buttonTint="#0DA4A6" android:layout_marginBottom="5dp"/>
                            <CheckBox android:id="@+id/chkShorts" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block YouTube Shorts" android:textColor="#333333" android:textSize="15sp" android:buttonTint="#0DA4A6" android:layout_marginBottom="15dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Custom Keywords:" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="10dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="10dp">
                                    <EditText android:id="@+id/keywordInputAdult" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:hint="e.g. badword" android:textSize="14sp" android:paddingStart="10dp"/>
                                </LinearLayout>
                                <Button android:id="@+id/btnAddKeywordAdult" android:layout_width="wrap_content" android:layout_height="40dp" android:text="+ Add" android:textColor="#FFFFFF" android:backgroundTint="#0DA4A6" android:insetTop="0dp" android:insetBottom="0dp"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="120dp" android:background="#E0E0E0" android:padding="1dp">
                                <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAFAFA">
                                    <LinearLayout android:id="@+id/keywordListContainerAdult" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp"/>
                                </ScrollView>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E0E0E0" android:padding="1dp" android:layout_marginBottom="15dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FAFAFA" android:orientation="horizontal" android:padding="15dp" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textColor="#0DA4A6" android:textSize="50sp" android:layout_marginEnd="15dp"/>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clean Streak" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Days" android:textColor="#0DA4A6" android:textStyle="bold" android:textSize="35sp" android:layout_marginTop="-5dp"/>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/viewStrictProtocols"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:paddingTop="10dp" android:paddingBottom="10dp" android:gravity="center">
                        <TextView android:id="@+id/tabSafeBrowsing2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Safe Browse" android:textColor="#666666" android:background="#F0F2F5" android:textStyle="bold" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                        <TextView android:id="@+id/tabStrictProtocols2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Strict Mode" android:textColor="#FFFFFF" android:textStyle="bold" android:background="#0DA4A6" android:gravity="center" android:paddingTop="12dp" android:paddingBottom="12dp" android:layout_margin="5dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="15dp">
                        
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Advanced Security &amp; Tracking:" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="15dp"/>

                        <CheckBox android:id="@+id/chkUrlTracking" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Silent URL Tracking" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="15sp" android:layout_marginBottom="10dp"/>
                        <CheckBox android:id="@+id/chkSafeSearch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Force SafeSearch" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="15sp" android:layout_marginBottom="10dp"/>
                        <CheckBox android:id="@+id/chkStrictMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Strict Mode (Anti-Bypass)" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="15sp" android:layout_marginBottom="10dp"/>
                        <CheckBox android:id="@+id/chkDnsBlock" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Strict DNS/Hosts Block" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="15sp" android:layout_marginBottom="10dp"/>
                        <CheckBox android:id="@+id/chkIncognito" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Block Incognito Tabs" android:buttonTint="#0DA4A6" android:textColor="#333333" android:textSize="15sp" android:layout_marginBottom="25dp"/>

                        <Button android:id="@+id/btnPanicLockdown" android:layout_width="match_parent" android:layout_height="50dp" android:text="PANIC LOCKDOWN (15m)" android:textColor="#FFFFFF" android:backgroundTint="#E53935" android:textStyle="bold" android:layout_marginBottom="15dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analytics: RasFocus protected you from 0 distractions." android:textColor="#0DA4A6" android:textStyle="bold" android:textSize="12sp" android:gravity="center" android:layout_gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0DA4A6"
        android:orientation="vertical"
        android:paddingTop="30dp"
        android:clickable="true"
        android:focusable="true">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RasFocus" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" android:paddingStart="20dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Adult &amp; apps blocker" android:textColor="#E0F2F1" android:textSize="12sp" android:paddingStart="20dp" android:layout_marginBottom="40dp" />

        <TextView android:id="@+id/menuBlocks" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Blocks" android:textColor="#0DA4A6" android:background="#FFFFFF" android:textStyle="bold" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>
        <TextView android:id="@+id/menuAdultBlock" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Adult Block" android:textColor="#FFFFFF" android:background="#0DA4A6" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>
        
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Deep Study" android:textColor="#FFFFFF" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Special Feature" android:textColor="#FFFFFF" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Statistics" android:textColor="#FFFFFF" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Settings" android:textColor="#FFFFFF" android:padding="15dp" android:paddingStart="20dp" android:textSize="16sp"/>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <Button android:layout_width="match_parent" android:layout_height="50dp" android:text="Upgrade to Pro" android:textColor="#FFFFFF" android:backgroundTint="#F59E0B" android:layout_margin="15dp" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
