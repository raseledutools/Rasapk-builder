<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0F172A"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RasFocus Control Center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Take a Break / Focus Mode"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/breakTimeInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:hint="Minutes (e.g. 30)"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:inputType="number"
                android:background="#1E293B"
                android:padding="10dp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnStartFocus"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Start Focus"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Block Custom Keywords"
            android:textColor="#00BCD4"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">

            <EditText
                android:id="@+id/keywordInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:hint="e.g. badword"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:inputType="text"
                android:background="#1E293B"
                android:padding="10dp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnAddKeyword"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="+ Add"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00BCD4"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/keywordListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="10dp"
            android:layout_marginBottom="20dp"
            android:minHeight="80dp">
            </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnClearKeywords"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Clear List"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnClose"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Close Panel"
                android:textColor="#FFFFFF"
                android:backgroundTint="#64748B"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
